{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/app",
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": [
      "node"
    ]
  },
  "files": [
    "main.ts",
    "main.server.ts",
    "server.ts"
  ],
  "angularCompilerOptions": {
    "flatTemplateTypeCheck": false,
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
